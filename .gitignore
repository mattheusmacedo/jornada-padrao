# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Environment files
.env
.env.*
!.env.example

# Third-party converter binaries (FBX2glTF, etc.) fetched on demand
scripts/bin/

# Dev-only model assets: kept locally for /model-sandbox comparison tabs,
# excluded from the deployed build to keep Vercel payload small. The
# canonical .glb files (latest version) ARE committed and shipped.
public/models-prebrand/
public/models/**/*.fbx
public/models/**/*.v[0-9]*.glb

# Stray temp screenshots from verification (contact sheets, frame grabs)
tmp-*.png
tmp-*.jpg
tmp-*.mp4
tmp-*.webm

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

.vercel
